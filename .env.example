# Google Forms Integration for Waitlist
# See WAITLIST_SETUP.md for detailed instructions on how to get these values
GOOGLE_FORM_ID=your_form_id_here
GOOGLE_FORM_EMAIL_ENTRY=your_email_entry_id
GOOGLE_FORM_AGE_ENTRY=your_age_entry_id
GOOGLE_FORM_LOCATION_ENTRY=your_location_entry_id

# Database (Supabase recommended - optional for future features)
# Get your credentials from https://supabase.com/dashboard/project/_/settings/api
DATABASE_URL=your_database_url_here
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Meta Pixel (for NutriNest validation tracking - optional)
NEXT_PUBLIC_META_PIXEL_ID=your_meta_pixel_id

# Email Service (optional - for waitlist notifications)
EMAIL_SERVICE_API_KEY=your_email_service_key

# MotoScout Configuration
MOTOSCOUT_ALLOWED_EMAIL=your@email.com
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Admin Portal
NEXT_PUBLIC_ADMIN_PASS=your_admin_password

# GitHub (optional - for higher API rate limits)
GITHUB_TOKEN=your_github_personal_access_token
